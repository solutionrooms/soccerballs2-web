<?xml version="1.0" encoding="utf-8"?>
<project>
	<meta title="Soccer Balls 2" package="com.solutionrooms.soccerballs2" version="1.0.0" company="SolutionRooms" />
	<app main="Main" path="bin" file="SoccerBalls2" />
	<window width="700" height="525" fps="60" background="#000000" allow-high-dpi="false" />
	<!-- HD build (-Dhd): render into a 2x-backed canvas so the 2x software buffers resolve crisply -->
	<window allow-high-dpi="true" if="hd" />

	<source path="src" />
	<!-- vendored + Haxe-4-patched as3hx runtime support: as3hx.Compat, FastXML (E4X), FastXMLList -->
	<source path="vendor" />

	<haxelib name="openfl" />
	<!-- openfljs: expose openfl display properties (text/x/alpha/currentFrame/…) as native JS
	     accessors via Object.defineProperties, so the original AS3's pervasive dynamic property
	     access (untyped mc.buttonName.text, etc.) routes through the real getters/setters instead
	     of reading raw fields that don't exist. Also enables named-instance assignment in the SWF
	     timeline (parent.childName), matching Flash. -->
	<haxedef name="openfljs" />
	<!-- Physics engine swap. DEFAULT build → nape-haxe4 2.0.22 (newer Nape, wrong feel).
	     `-Dreplica` build → the bit-exact 2012-Nape replica via a Haxe `nape.*` shim package
	     (nape-shim/) that re-presents the same nape-haxe4 API the game already calls and routes
	     to the bundled TS engine (nape-replica.js, global `NapeReplica`). Zero game-code edits:
	     the game's `import nape.*` bind to the shim instead of the haxelib. -->
	<haxelib name="nape-haxe4" unless="replica" />
	<source path="nape-shim" if="replica" />
	<!-- original SWF library symbols (UI clips, character rigs, fonts) -->
	<haxelib name="swf" />
	<library path="assets/SoccerBalls2.swf" generate="true" preload="true" />

	<!-- original game data + texture pages, embedded like the release SWF -->
	<assets path="assets" rename="assets" embed="true" />
	<!-- converted audio (OGG): external + preloaded so the ~2MB music doesn't bloat the JS bundle;
	     explicit type="sound" so Assets.getSound() resolves them (see AudioPackage/Audio.AddSound). -->
	<assets path="assets/audio" rename="assets/audio" embed="false" type="sound" />
	<!-- game font (Komika Axis): external file so it can be served as a browser webfont via the
	     FontFace API (GameFont.Load) at the URL assets/fonts/KomikaAxis.ttf. -->
	<assets path="assets/fonts" rename="assets/fonts" embed="false" />

	<!-- Override the html5 shell (templates/html5/template/index.html). MUST come after <haxelib name="openfl">
	     so our template registers last and wins over OpenFL's own index.html. Pins the game container to the
	     full visual viewport so lime letterbox-scales the 700x525 stage UP to fill it — landscape was leaving
	     the canvas at ~native size with large black margins. -->
	<template path="templates" />
</project>
