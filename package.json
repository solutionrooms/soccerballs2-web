{
  "name": "soccerballs2-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "extract": "tsx tools/extract-atlas.ts && tsx tools/extract-objects.ts && tsx tools/extract-levels.ts && tsx tools/extract-misc.ts",
    "test": "vitest run",
    "replica:bundle": "esbuild src/physics/replica/bundle-entry.ts --bundle --format=iife --target=es2017 --legal-comments=none --outfile=haxe-port/templates/html5/template/nape-replica.js && cp haxe-port/templates/html5/template/nape-replica.js haxe-port/bin/html5/bin/nape-replica.js",
    "replica:build": "npm run replica:bundle && cd haxe-port && haxelib run lime build html5 -Dreplica",
    "replica:serve": "node scripts/serve-replica.cjs"
  },
  "dependencies": {
    "earcut": "^3.0.2",
    "puppeteer-core": "^24.43.1"
  },
  "devDependencies": {
    "@types/earcut": "^3.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
